pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out code...'
            }
        }

        stage('Build') {
            steps {
                echo 'Running MATLAB Build...'
            }
        }

        stage('Test') {
            steps {
                echo 'Running Tests...'
            }
        }
    }
}
